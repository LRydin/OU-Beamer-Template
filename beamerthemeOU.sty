\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeOU}[2026/05/28 v0.0.3 OU Beamer Theme Open Universiteit]

% --------------------------------------------------------------------------
% Package purpose
% --------------------------------------------------------------------------
% This file defines a Beamer presentation theme for the Open Universiteit.
% It provides:
%   - OU colour definitions and hyperlink styling;
%   - language-dependent institute and page labels;
%   - font selection for XeLaTeX/LuaLaTeX, with a pdfLaTeX fallback;
%   - frame title, title page, footline, list, block, and caption styling;
%   - footer short-title display enabled by default through footertitle=true;
%   - a per-frame accent-colour option: [framecolor=<xcolor name>];
%   - a custom outline list environment: ououtline;
%   - embedded OU logo drawings at the end of the file.
%
% Typical use in a presentation:
%
%   \documentclass[10pt,aspectratio=169]{beamer}
%   \usetheme[
%     lang=en,
%     font=arial,
%     elevatedtitles=false,
%     serifmath=true,
%     tightlists=true,
%     footertitle=true
%   ]{OU}
%
% Compile with XeLaTeX or LuaLaTeX for Arial/Calibri system fonts. With
% pdfLaTeX, the theme falls back to Helvetica when font is not set to none.
%
% --------------------------------------------------------------------------


\makeatletter

% --------------------------------------------------------------------------
% 1. Required packages
% --------------------------------------------------------------------------
% kvoptions processes key-value theme options passed through \usetheme.
% etoolbox is used for string comparisons and for patching Beamer internals.
% TikZ is used by the title page, footline, outline rule, and logo commands.

\RequirePackage{kvoptions}
\RequirePackage[dvipsnames]{xcolor}
\RequirePackage{graphicx}
\RequirePackage{etoolbox}
\RequirePackage{ifxetex}
\RequirePackage{ifluatex}

\RequirePackage{tikz}
\usetikzlibrary{calc}
\usetikzlibrary{intersections}
\usetikzlibrary{positioning}

% --------------------------------------------------------------------------
% 2. Theme options
% --------------------------------------------------------------------------
% Options are passed by Beamer through \usetheme[...]{OU}; internally this is
% loaded as a package option list, which kvoptions processes here.
%
% font:
%   arial   : use Arial via fontspec under XeLaTeX/LuaLaTeX
%   calibri : use Calibri via fontspec under XeLaTeX/LuaLaTeX
%   none    : do not alter the document fonts
%
% elevatedtitles:
%   true  : compact title strip, leaving more vertical space on the slide
%   false : taller title strip
%
% serifmath:
%   true  : keep mathematics in a serif math font
%   false : use Beamer's default sans-style math behaviour
%
% tightlists:
%   true  : slightly tighter standard itemize lists
%   false : leave Beamer defaults mostly untouched
%
% footertitle:
%   true  : show the plain short title in the rounded footer bar (default)
%   false : show only the page number in the rounded footer bar
%
% lang:
%   en : English labels
%   nl : Dutch labels

\SetupKeyvalOptions{family=OU,prefix=OU@}

\DeclareStringOption[arial]{font}
\DeclareBoolOption[false]{elevatedtitles}
\DeclareBoolOption[true]{serifmath}
\DeclareBoolOption[true]{tightlists}
\DeclareBoolOption[true]{footertitle}
\DeclareStringOption[en]{lang}

\ProcessKeyvalOptions*

% --------------------------------------------------------------------------
% 3. Language-dependent strings
% --------------------------------------------------------------------------
% These strings are used for babel, the default institute, and the page label
% in the footline. Unknown language options fall back to English.

\def\OU@babel@en{english}
\def\OU@babel@nl{dutch}

\providecommand\OU@inst@en{Open University of the Netherlands}
\providecommand\OU@inst@nl{Open Universiteit}

\providecommand\OU@page@en{page}
\providecommand\OU@page@nl{pagina}

\@ifundefined{OU@babel@\OU@lang}{%
  \PackageWarning{beamerthemeOU}{Unknown language '\OU@lang'. Falling back to English}%
  \def\OU@lang{en}%
}{}

\newcommand*\OU@babelname{\csname OU@babel@\OU@lang\endcsname}
\newcommand*\OU@InstituteName{\csname OU@inst@\OU@lang\endcsname}
\newcommand*\OU@PageName{\csname OU@page@\OU@lang\endcsname}

\expandafter\RequirePackage\expandafter[\OU@babelname]{babel}
\institute{\OU@InstituteName}

% --------------------------------------------------------------------------
% 4. OU colour palette
% --------------------------------------------------------------------------
% OUPrimary is the main red accent used for titles, logos, and the footline.
% The remaining colours are secondary accents for blocks, lists, and custom
% content. The colour names are intentionally stable so user documents can
% rely on them.

\definecolor{OUblack}{HTML}{000000}
\definecolor{OUwhite}{HTML}{FFFFFF}

\definecolor{OUPrimary}{RGB}{226,0,26}
\definecolor{OUAccent2}{HTML}{E7E3D1}
\definecolor{OUAccent3}{HTML}{5967A6}
\definecolor{OUwarmgrey}{HTML}{E8E3DC}
\definecolor{OUgreenish}{HTML}{A1B7AC}
\definecolor{OUlightblue}{RGB}{205,222,0}

% --------------------------------------------------------------------------
% 5. Hyperlinks
% --------------------------------------------------------------------------
% Hyperlinks use the primary OU accent colour. The URL font is kept consistent
% with surrounding text.

\RequirePackage{hyperref}

\hypersetup{
  colorlinks=true,
  citecolor=OUPrimary,
  linkcolor=OUPrimary,
  urlcolor=OUPrimary
}

\urlstyle{same}
\DeclareUrlCommand\url{\color{OUPrimary}}

% --------------------------------------------------------------------------
% 6. Font setup
% --------------------------------------------------------------------------
% Under XeLaTeX/LuaLaTeX, fontspec is used if font is arial or calibri.
% Under pdfLaTeX, Helvetica is used as a fallback unless font=none.
% With font=none, no font package is loaded by the theme.

\newif\ifOU@usefontspec
\OU@usefontspecfalse

\ifxetex
  \OU@usefontspectrue
\fi
\ifluatex
  \OU@usefontspectrue
\fi

\ifdefstring{\OU@font}{none}{%
  \OU@usefontspecfalse
}{}

\ifOU@usefontspec
  \RequirePackage{fontspec}
  \ifdefstring{\OU@font}{calibri}{%
    \setsansfont{Calibri}
    \setmainfont{Calibri}
  }{%
    \setsansfont{Arial}
    \setmainfont{Arial}
  }%
\else
  \ifdefstring{\OU@font}{none}{%
    % Leave all font choices to the document.
  }{%
    \RequirePackage[scaled=0.92]{helvet}
    \renewcommand{\familydefault}{\sfdefault}
  }%
\fi

\ifOU@serifmath
  \usefonttheme[onlymath]{serif}
\fi

% --------------------------------------------------------------------------
% 7. Layout constants
% --------------------------------------------------------------------------
% \OU@frametitleheight controls the vertical height of the frame-title area.
% The name "elevatedtitles" is kept as a user-facing option for compatibility.

\newcommand*\OU@frametitleheight{7ex}
\ifOU@elevatedtitles
  \renewcommand*\OU@frametitleheight{3.0ex}
\fi

\setlength{\abovecaptionskip}{5pt plus 3pt minus 2pt}

% --------------------------------------------------------------------------
% 8. Core Beamer colours, fonts, and spacing
% --------------------------------------------------------------------------

\mode<presentation>

% Base text and structural colours.
\setbeamercolor{normal text}{fg=OUblack,bg=OUwhite}
\setbeamercolor{structure}{fg=OUPrimary}
\setbeamercolor{alerted text}{fg=OUAccent2}

% Typography for standard Beamer elements.
\setbeamerfont{frametitle}{size=\Large,series=\bfseries}
\setbeamerfont{framesubtitle}{size=\normalsize}

\setbeamerfont{title}{size=\huge,series=\bfseries}
\setbeamerfont{subtitle}{size=\large}
\setbeamerfont{author}{size=\large}
\setbeamerfont{institute}{size=\large}
\setbeamerfont{date}{size=\large}

\setbeamerfont{block title}{size=\normalsize}
\setbeamerfont{footnote}{size=\scriptsize}

% Slide margins and paragraph rhythm.
\setbeamersize{text margin left=12mm,text margin right=10mm}
\linespread{1.06}
\setlength{\parskip}{0.28\baselineskip}

% Standard list style.
\setbeamercolor{itemize item}{fg=OUPrimary}
\setbeamercolor{itemize subitem}{fg=OUAccent3}
\setbeamertemplate{itemize item}{\raise0.6pt\hbox{\large\textbullet}}
\setbeamertemplate{itemize subitem}{\textendash}

\ifOU@tightlists
  \setlength{\leftmargini}{1.4em}
  \setlength{\itemsep}{0.25\baselineskip}
\fi

% Block style. All block variants currently share the same styling.
\setbeamertemplate{blocks}[rounded][shadow=false]
\setbeamercolor{block title}{fg=OUblack,bg=OUlightblue}
\setbeamercolor{block body}{fg=OUblack,bg=OUwarmgrey}
\setbeamercolor{block title example}{fg=OUblack,bg=OUlightblue}
\setbeamercolor{block body example}{fg=OUblack,bg=OUwarmgrey}
\setbeamercolor{block title alerted}{fg=OUblack,bg=OUlightblue}
\setbeamercolor{block body alerted}{fg=OUblack,bg=OUwarmgrey}

% Header/footer helper colours.
\setbeamercolor{author in head/foot}{fg=OUPrimary,bg=}
\setbeamercolor{date in head/foot}{fg=OUPrimary,bg=}
\setbeamercolor{OU foot rule}{fg=OUPrimary,bg=}

% General Beamer templates.
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]

% --------------------------------------------------------------------------
% 9. Per-frame accent colour and footline options
% --------------------------------------------------------------------------
% The frame accent controls the OU logo and the rounded footer shape.
%
% Usage:
%
%   \begin{frame}[framecolor=OUAccent3]{A different accent}
%     ...
%   \end{frame}
%
% The default footline is placed on the lower right. Two per-frame options
% modify this behaviour:
%
%   \begin{frame}[leftfootline]{Mirrored footer}
%     ...
%   \end{frame}
%
%   \begin{frame}[nofootline]{No bottom footer}
%     ...
%   \end{frame}
%
% The nofootline option removes the bottom rounded bar, title, and page number,
% but deliberately keeps the OU logo. If leftfootline and nofootline are both
% used, the logo is mirrored to the upper-left position and the bottom footer is
% suppressed.
%
% These per-frame options are reset at the start of every frame, so they do not
% affect subsequent frames.

\newcommand*\OU@frameaccentdefault{OUPrimary}
\def\OU@frameaccent{\OU@frameaccentdefault}

\newif\ifOU@leftfootline
\newif\ifOU@nofootline
\OU@leftfootlinefalse
\OU@nofootlinefalse

\define@key{beamerframe}{framecolor}{%
  \def\OU@frameaccent{#1}%
}

\define@key{beamerframe}{leftfootline}[true]{%
  \ifdefstring{#1}{false}{%
    \OU@leftfootlinefalse
  }{%
    \OU@leftfootlinetrue
  }%
}

\define@key{beamerframe}{nofootline}[true]{%
  \ifdefstring{#1}{false}{%
    \OU@nofootlinefalse
  }{%
    \OU@nofootlinetrue
  }%
}

\AtBeginDocument{%
  \pretocmd{\beamer@@@@frame}{%
    \def\OU@frameaccent{\OU@frameaccentdefault}%
    \OU@leftfootlinefalse
    \OU@nofootlinefalse
  }{}{%
    \PackageWarning{beamerthemeOU}{Could not patch Beamer frame initialisation; frame options may persist across frames}%
  }%
}

% --------------------------------------------------------------------------
% 10. Frame title template
% --------------------------------------------------------------------------
% The frame title is left-aligned and coloured by the current frame accent.
% The subtitle is printed directly below the title when present.

\setbeamercolor{frametitle}{fg=,bg=}

\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \begin{beamercolorbox}[
    wd=\paperwidth,
    ht=\OU@frametitleheight,
    dp=1.6ex,
    leftskip=12mm,
    rightskip=10mm
  ]{frametitle}
    \usebeamerfont{frametitle}%
    \textcolor{OUblack}{\insertframetitle}%
    \\[0.1em]%
    \usebeamerfont{framesubtitle}\insertframesubtitle
  \end{beamercolorbox}%
}

% --------------------------------------------------------------------------
% 11. Footline template
% --------------------------------------------------------------------------
% The footline consists of two independent layers:
%   - the OU logo in the upper corner;
%   - the bottom rounded footer bar with the optional short title and page
%     number.
%
% By default, these elements are drawn on the right-hand side. The per-frame
% option [leftfootline] mirrors the layout to the left-hand side. The per-frame
% option [nofootline] suppresses only the bottom footer bar and its text, while
% keeping the OU logo visible.
%
% Footer title handling avoids Beamer's linked \insertshorttitle machinery.
% Instead, the theme stores a plain copy of the optional short title supplied
% with:
%
%   \title[Short footer title]{Full presentation title}
%
% The footer title can also be overridden manually:
%
%   \OUfootertitle{Manual footer title}

\newcommand*\OU@footertitletext{}

\newcommand*\OUfootertitle[1]{%
  \long\gdef\OU@footertitletext{#1}%
}

\let\OU@originaltitle\title

\renewcommand{\title}{%
  \@dblarg\OU@title%
}

\long\def\OU@title[#1]#2{%
  \OU@originaltitle[#1]{#2}%
  \long\gdef\OU@footertitletext{#1}%
}

\newcommand*\OU@insertfootertitle{%
  \begingroup
  \let\thanks\@gobble
  \OU@footertitletext
  \endgroup
}

% Right-hand layout: default.
\newcommand*\OU@drawrightlogo{%
  \node[below right,inner sep=0pt]
    at ($(current page.north east)+(-0.75,-0.38)$)
    {\enlogonotext{\OU@frameaccent}};%
}

\newcommand*\OU@drawrightfooterbar{%
  \fill[\OU@frameaccent]
    ($(current page.south east)+(0,0.93)$)
    --++ (-5.3,0)
    arc[start angle=90,end angle=270,radius=0.29]
    --++ (5.3,0)
    -- cycle;%
}

\newcommand*\OU@drawrightfootertext{%
  \ifOU@footertitle
    \node[
      anchor=east,
      text=OUwhite,
      inner sep=0pt,
      align=right,
      text width=3.65cm
    ]
      at ($(current page.south east)+(-1.55,0.64)$)
      {%
        \fontsize{5.2pt}{6pt}\selectfont
        \OU@insertfootertitle\par
      };
  \fi
  \node[
    anchor=east,
    text=OUwhite,
    inner sep=0pt,
    align=right
  ]
    at ($(current page.south east)+(-0.62,0.64)$)
    {%
      \fontsize{5.2pt}{6pt}\selectfont
      \OU@PageName~\insertframenumber\par
    };%
}

\newcommand*\OU@drawrightfootline{%
  \OU@drawrightlogo
  \ifOU@nofootline
    % Keep only the logo.
  \else
    \OU@drawrightfooterbar
    \OU@drawrightfootertext
  \fi
}

% Left-hand layout: mirror of the default.
\newcommand*\OU@drawleftlogo{%
  \node[below left,inner sep=0pt]
    at ($(current page.north west)+(0.75,-0.38)$)
    {\enlogonotext{\OU@frameaccent}};%
}

\newcommand*\OU@drawleftfooterbar{%
  \fill[\OU@frameaccent]
    ($(current page.south west)+(0,0.93)$)
    --++ (5.3,0)
    arc[start angle=90,end angle=-90,radius=0.29]
    --++ (-5.3,0)
    -- cycle;%
}

\newcommand*\OU@drawleftfootertext{%
  \ifOU@footertitle
    \node[
      anchor=west,
      text=OUwhite,
      inner sep=0pt,
      align=left,
      text width=3.65cm
    ]
      at ($(current page.south west)+(1.55,0.64)$)
      {%
        \fontsize{5.2pt}{6pt}\selectfont
        \OU@insertfootertitle\par
      };
  \fi
  \node[
    anchor=west,
    text=OUwhite,
    inner sep=0pt,
    align=left
  ]
    at ($(current page.south west)+(0.62,0.64)$)
    {%
      \fontsize{5.2pt}{6pt}\selectfont
      \OU@PageName~\insertframenumber\par
    };%
}

\newcommand*\OU@drawleftfootline{%
  \OU@drawrightlogo
  \ifOU@nofootline
    % Keep only the logo.
  \else
    \OU@drawleftfooterbar
    \OU@drawleftfootertext
  \fi
}

\setbeamertemplate{footline}{%
  \begin{tikzpicture}[overlay,remember picture]
    \ifOU@leftfootline
      \OU@drawleftfootline
    \else
      \OU@drawrightfootline
    \fi
  \end{tikzpicture}%
}

% Reserve vertical room for the custom footline.
% The space is intentionally kept also for [nofootline], so the slide content
% does not shift when toggling the footer visibility on individual frames.
\addtobeamertemplate{footline}{}{\vspace{0.75cm}}

% --------------------------------------------------------------------------
% 12. Title page template
% --------------------------------------------------------------------------
% The title page uses the primary OU colour, independent of per-frame accent
% changes. Use \begin{frame}[plain,noframenumbering]\titlepage\end{frame}.

\setbeamercolor{title}{fg=OUwhite,bg=OUwhite}

\defbeamertemplate*{title page}{OU}[1][]{%
  \begin{tikzpicture}[overlay,remember picture]

    \node[below right,inner sep=0pt]
      at ($(current page.north west)+(0.92,-0.8)$)
      {\enlogo{OUPrimary}};

    \fill[OUPrimary]
      ($(current page.north west)+(0,-3.5)$)
      --++ (7.75,0)
      arc[start angle=90,end angle=-90,radius=3.3]
      --++ (-7.75,0)
      -- cycle;

    \node[
      right,
      OUwhite,
      inner sep=0pt,
      align=left,
      text width=10cm
    ] (T) at ($(current page.north west)+(0.9,-5)$)
      {%
        \usebeamerfont{frametitle}%
        \fontsize{18pt}{20pt}\selectfont
        \raggedright\inserttitle\par
      };

    \ifx\insertsubtitle\@empty\else
      \node[
        OUwhite,
        inner sep=0pt,
        below=1.2em of T.south west,
        anchor=north west
      ] (ST)
      {%
        \fontsize{10pt}{12pt}\selectfont
        \insertsubtitle\par
      };
    \fi

    \node[
      right,
      OUwhite,
      inner sep=0pt,
      align=left,
      text width=10cm
    ] (A) at ($(current page.north west)+(0.9,-7.5)$)
      {%
        \fontsize{10pt}{12pt}\selectfont
        \insertauthor\par
      };

    \node[
      OUwhite,
      inner sep=0pt,
      below=0.5em of A.south west,
      anchor=north west
    ] (D)
    {%
      \fontsize{10pt}{12pt}\selectfont
      \insertdate\par
    };

    \node[
      OUwhite,
      inner sep=0pt,
      below=0.5em of D.south west,
      anchor=north west
    ] (I)
    {%
      \fontsize{10pt}{12pt}\selectfont
      \insertinstitute\par
    };

  \end{tikzpicture}%
}

\setbeamertemplate{title page}[OU]

% --------------------------------------------------------------------------
% 13. Footnotes
% --------------------------------------------------------------------------
% The default footnote rule is removed for a cleaner Beamer layout.

\renewcommand\footnoterule{}

% --------------------------------------------------------------------------
% 14. OU outline environment
% --------------------------------------------------------------------------
% A custom numbered outline list with:
%   - red/accent-coloured numbers;
%   - a vertical accent rule between numbers and text;
%   - bold item titles;
%   - smaller grey detail text.
%
% Basic usage:
%
%   \begin{ououtline}
%     \item<1-> First subject
%     \itemdetails<1-> First subject details
%
%     \item<2-> Second subject
%     \itemdetails<3-> Second subject details, appearing later
%   \end{ououtline}
%
% Optional colour override:
%
%   \begin{ououtline}[OUAccent3]
%     ...
%   \end{ououtline}
%
% By default, the outline accent follows the current frame accent.

\newcounter{ououtlineitem}
\newcounter{ououtlineblock}

% Horizontal geometry.
\newlength{\OUoutlineNumberWidth}
\newlength{\OUoutlineNumberSep}
\newlength{\OUoutlineRuleWidth}
\newlength{\OUoutlineTextSep}
\newlength{\OUoutlineRuleX}
\newlength{\OUoutlineLeftMargin}

% Vertical geometry.
\newlength{\OUoutlineItemSep}
\newlength{\OUoutlineTopAdjust}
\newlength{\OUoutlineBottomAdjust}
\newlength{\OUoutlineNumberRaise}
\newlength{\OUoutlineDetailSkip}

\setlength{\OUoutlineNumberWidth}{0.75cm}
\setlength{\OUoutlineNumberSep}{0.45cm}
\setlength{\OUoutlineRuleWidth}{0.55pt}
\setlength{\OUoutlineTextSep}{0.55cm}

\setlength{\OUoutlineItemSep}{0.32cm}
\setlength{\OUoutlineTopAdjust}{0.18cm}
\setlength{\OUoutlineBottomAdjust}{-0.35cm}
\setlength{\OUoutlineNumberRaise}{-0.8em}
\setlength{\OUoutlineDetailSkip}{-0.25em}

% Typography and colour hooks.
% These commands are deliberately user-redefinable.
\newcommand{\OUoutlineNumberFont}{%
  \fontsize{16pt}{18pt}\bfseries\selectfont%
}

\newcommand{\OUoutlineTitleFont}{%
  \fontsize{12pt}{14pt}\bfseries\selectfont%
}

\newcommand{\OUoutlineDetailFont}{%
  \fontsize{10pt}{12pt}\normalfont\selectfont%
}

\newcommand{\OUoutlineTitleColour}{OUblack}
\newcommand{\OUoutlineDetailColour}{black!55}

\makeatletter

\newenvironment{ououtline}[1][\OU@frameaccent]{%
  \par
  \begingroup
  \stepcounter{ououtlineblock}%
  \setcounter{ououtlineitem}{0}%
  %
  \colorlet{OUoutlineAccent}{#1}%
  %
  \setlength{\OUoutlineRuleX}{%
    \dimexpr\OUoutlineNumberWidth+\OUoutlineNumberSep\relax%
  }%
  %
  \setlength{\OUoutlineLeftMargin}{%
    \dimexpr
      \OUoutlineNumberWidth
      + \OUoutlineNumberSep
      + \OUoutlineRuleWidth
      + \OUoutlineTextSep
    \relax%
  }%
  %
  % Top coordinate for the vertical rule.
  \tikz[remember picture,overlay]
    \coordinate (ououtline-top-\theououtlineblock);
  %
  \begin{list}{}{%
    \setlength{\labelwidth}{\OUoutlineNumberWidth}%
    \setlength{\labelsep}{%
      \dimexpr
        \OUoutlineNumberSep
        + \OUoutlineRuleWidth
        + \OUoutlineTextSep
      \relax%
    }%
    \setlength{\leftmargin}{\OUoutlineLeftMargin}%
    \setlength{\rightmargin}{0pt}%
    \setlength{\topsep}{0pt}%
    \setlength{\partopsep}{0pt}%
    \setlength{\parsep}{0pt}%
    \setlength{\itemsep}{\OUoutlineItemSep}%
  }%
  %
  % Save Beamer's original overlay-aware \item.
  \let\OUoutlineOldItem\item
  %
  % Overlay-aware item.
  % The <...> specification is captured as ##1 and forwarded to
  % Beamer's original \item, so \item<2-> behaves as expected.
  \renewcommand<>{\item}{%
    \onslide<1->%
    \stepcounter{ououtlineitem}%
    \OUoutlineOldItem##1[%
      \hbox to \OUoutlineNumberWidth{%
        \hfil
        \raisebox{\OUoutlineNumberRaise}{%
          {\OUoutlineNumberFont\color{OUoutlineAccent}\arabic{ououtlineitem}}%
        }%
      }%
    ]%
    \OUoutlineTitleFont
    \color{\OUoutlineTitleColour}%
    \ignorespaces
  }%
  %
  % Overlay-aware details command.
  % Without an overlay specification, the details inherit the visibility
  % state of the preceding \item. With <...>, they can be delayed separately.
  \newcommand<>{\OUoutlineItemDetails}{%
    \par
    \vspace{\OUoutlineDetailSkip}%
    \OUoutlineDetailFont
    \color{\OUoutlineDetailColour}%
    \def\OUoutlineOverlaySpec{##1}%
    \ifx\OUoutlineOverlaySpec\@empty
    \else
      \onslide##1%
    \fi
    \ignorespaces
  }%
  %
  \let\itemdetails\OUoutlineItemDetails
}{%
  \end{list}%
  %
  % Bottom coordinate for the vertical rule.
  \tikz[remember picture,overlay]
    \coordinate (ououtline-bottom-\theououtlineblock);
  %
  % Draw the vertical rule.
  \begin{tikzpicture}[remember picture,overlay]
    \draw[
      OUoutlineAccent,
      line width=\OUoutlineRuleWidth
    ]
      ([xshift=\OUoutlineRuleX,yshift=-\OUoutlineTopAdjust]
        ououtline-top-\theououtlineblock)
      --
      ([xshift=\OUoutlineRuleX,yshift=-\OUoutlineBottomAdjust]
        ououtline-bottom-\theououtlineblock);
  \end{tikzpicture}%
  %
  \par
  \endgroup
}

\makeatother

% --------------------------------------------------------------------------
% 15. Logo commands
% --------------------------------------------------------------------------
% The logo commands are deliberately kept at the end of the file because they
% consist of long TikZ paths.
%
%   \enlogo{<colour>}       : full OU logo with text
%   \enlogonotext{<colour>} : compact OU icon without text
%
% --------------------------------------------------------------------------
